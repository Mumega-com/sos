name = "sos-bus"
main = "src/index.ts"
compatibility_date = "2024-01-01"
workers_dev = true
account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"

[[routes]]
pattern = "bus.example.com/*"
zone_id = "YOUR_CLOUDFLARE_ZONE_ID"

[[d1_databases]]
binding = "DB"
database_name = "sos-bus"
database_id = "YOUR_D1_DATABASE_ID"

[[kv_namespaces]]
binding = "KV"
id = "YOUR_KV_NAMESPACE_ID"

[[r2_buckets]]
binding = "SDK"
bucket_name = "sos-sdk"

[vars]
ORIGIN_URL = "http://YOUR_ORIGIN_IP:6380"
