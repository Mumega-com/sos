[Unit]
Description=SOS Brain — scoring and dispatch
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
WorkingDirectory=/mnt/HC_Volume_104325311/SOS
EnvironmentFile=/home/mumega/.env.secrets
Environment=PYTHONPATH=/mnt/HC_Volume_104325311/SOS
ExecStart=/usr/bin/python3 -m sos.services.brain
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
