    "chapters": {
      "items": {
        "$ref": "#/$defs/MediaChapter"
      },
      "title": "Chapters",
      "type": "array"
    },
    "transcript": {
      "title": "Transcript",
      "type": "string"
    }
  },
  "required": [
    "transcript",
    "chapters"
  ],
  "title": "MediaTranscribeResult",
  "type": "object"
