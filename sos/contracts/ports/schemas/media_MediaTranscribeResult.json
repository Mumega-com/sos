          "description": "Seconds from start of asset",
          "title": "Time",
          "type": "number"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "time",
        "title"
      ],
      "title": "MediaChapter",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Transcription + chapter output for a video/audio asset.",
