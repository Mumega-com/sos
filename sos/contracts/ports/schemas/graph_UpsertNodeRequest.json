{
  "$defs": {
    "GraphNode": {
      "additionalProperties": false,
      "description": "Directly mirrors Inkwell's GraphNode.",
      "properties": {
        "author": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Author"
        },
        "date": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Date"
        },
        "slug": {
          "minLength": 1,
          "title": "Slug",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "tenant": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Which tenant owns this node. None = platform-level.",
          "title": "Tenant"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "type": {
          "description": "'blog' | 'topic' | 'concept' | 'lab' | ...",
          "title": "Type",
          "type": "string"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "visibility": {
          "default": "private",
          "enum": [
            "public",
            "private"
          ],
          "title": "Visibility",
          "type": "string"
        }
      },
      "required": [
        "slug",
        "title",
        "type"
      ],
      "title": "GraphNode",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "node": {
      "$ref": "#/$defs/GraphNode"
    },
    "tenant_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tenant Id"
    }
  },
  "required": [
    "node"
  ],
  "title": "UpsertNodeRequest",
  "type": "object"
}
