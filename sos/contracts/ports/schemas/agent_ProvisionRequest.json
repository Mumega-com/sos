{
  "$defs": {
    "McpServerRef": {
      "additionalProperties": false,
      "properties": {
        "token": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Token"
        },
        "url": {
          "title": "Url",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "title": "McpServerRef",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Create a new managed agent for a tenant. `status`/`created_at`/\n`updated_at` are assigned by the service.",
  "properties": {
    "agent_id": {
      "title": "Agent Id",
      "type": "string"
    },
    "anthropic_agent_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Anthropic Agent Id"
    },
    "budget_per_day": {
      "minimum": 0,
      "title": "Budget Per Day",
      "type": "integer"
    },
    "budget_per_month": {
      "minimum": 0,
      "title": "Budget Per Month",
      "type": "integer"
    },
    "mcp_servers": {
      "items": {
        "$ref": "#/$defs/McpServerRef"
      },
      "title": "Mcp Servers",
      "type": "array"
    },
    "model": {
      "enum": [
        "haiku",
        "sonnet",
        "opus"
      ],
      "title": "Model",
      "type": "string"
    },
    "system_prompt": {
      "title": "System Prompt",
      "type": "string"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    },
    "tools": {
      "items": {
        "type": "string"
      },
      "title": "Tools",
      "type": "array"
    }
  },
  "required": [
    "tenant_id",
    "agent_id",
    "model",
    "system_prompt",
    "budget_per_day",
    "budget_per_month"
  ],
  "title": "ProvisionRequest",
  "type": "object"
}
