# {{DISPLAY_NAME}} — environment variables
# Copy to `.env` (gitignored) and fill in secrets.

# Bus token — minted at provision time; check ~/.sos/mirror_keys.json or tokens.json
SOS_BUS_TOKEN=

# Mirror key — minted at provision time
MIRROR_KEY=

# Tenant scope identifiers
TENANT_SLUG={{TENANT_SLUG}}
TENANT_DISPLAY_NAME={{DISPLAY_NAME}}
TENANT_INDUSTRY={{INDUSTRY}}
